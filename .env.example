# PlumbTix — Frontend Environment Variables
# Copy to .env.local and fill in values

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-local-anon-key
VITE_EDGE_BASE_URL=http://127.0.0.1:54321/functions/v1

# Sentry DSN for frontend error tracking (optional)
VITE_SENTRY_DSN=

# Email sandbox mode (set to "true" to show sandbox banner)
VITE_RESEND_SANDBOX=false

# Base URL used in public share links + printed QR codes (no trailing slash).
# Falls back to window.location.origin when unset.
# Production: https://workorders.proroto.com
VITE_PUBLIC_APP_URL=
